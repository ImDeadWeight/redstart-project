{
  "name": "beaver-log-windows",
  "version": "1.0.0",
  "description": "Lightweight Windows chat client for connecting to a Beaver Dam or llama.cpp-compatible server on your local network.",
  "author": "Patrick Carswell",
  "private": true,
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "build:chat": "npm --prefix ../../beaver-dam/src/chat-ui run build",
    "build": "npm run build:chat && node ../../beaver-dam/scripts/make-icon.mjs && electron-builder",
    "dev": "electron ."
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^24.13.3"
  }
}
