{
  "$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",
  "appId": "com.redstart.twig",
  "productName": "Redstart Twig",
  "directories": {
    "output": "release/${version}"
  },
  "files": [
    "electron/**/*"
  ],
  "asarUnpack": [
    "electron/preload.cjs"
  ],
  "extraResources": [
    {
      "from": "../../redstart-nest/src/chat-ui/dist",
      "to": "chat-ui",
      "filter": ["**/*"]
    }
  ],
  "win": {
    "target": "nsis",
    "icon": "../../redstart-nest/build/icon.ico"
  },
  "nsis": {
    "oneClick": false,
    "allowElevation": true,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "Redstart Twig",
    "license": "LICENSE.txt",
    "installerIcon": "../../redstart-nest/build/icon.ico",
    "uninstallerIcon": "../../redstart-nest/build/icon.ico",
    "runAfterFinish": true
  }
}
