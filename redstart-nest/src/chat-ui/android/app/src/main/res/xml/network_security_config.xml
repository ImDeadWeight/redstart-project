<?xml version="1.0" encoding="utf-8"?>
<!--
    Allow cleartext HTTP traffic so the app can reach the local llama.cpp
    server on the LAN without requiring TLS.  This is intentional: all
    traffic stays on the private home/office network.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
