{
  "$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",
  "appId": "com.redstart.nest",
  "productName": "Redstart Nest",
  "directories": {
    "output": "release/${version}"
  },
  "files": [
    "electron/main",
    "electron/preload",
    "dist"
  ],
  "extraResources": [
    {
      "from": "src/chat-ui/dist",
      "to": "chat-ui",
      "filter": ["**/*"]
    },
    {
      "from": "llama-cpp-turboquant/build/bin/Release",
      "to": "bin",
      "filter": ["llama-server.exe", "*.dll"]
    },
    {
      "from": "deps/windows",
      "to": "bin",
      "filter": ["*.dll"]
    }
  ],
  "win": {
    "target": "nsis",
    "icon": "build/icon.ico"
  },
  "nsis": {
    "oneClick": false,
    "allowElevation": true,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "Redstart Nest",
    "license": "LICENSE.txt",
    "installerIcon": "build/icon.ico",
    "uninstallerIcon": "build/icon.ico",
    "runAfterFinish": true
  }
}
